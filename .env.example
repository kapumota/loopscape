# Configuracion LLM para Loopscape
# Copia este archivo a .env y completa tu clave local

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic como alternativa
# ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# URL del proxy para WASM
# Set this to your deployed proxy or local proxy
LLM_PROXY_URL=http://localhost:3001/api/llm
# LLM_PROXY_URL=https://your-worker.your-subdomain.workers.dev/api/llm

# Usa modo simulado para pruebas sin llamadas externas
LLM_MOCK_MODE=true
